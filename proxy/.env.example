# ─── Provider priority ────────────────────────────────────────────────────────
# Comma-separated list, first = primary. The router tries providers left-to-right.
PROVIDER_PRIORITY=openrouter,nvidia

# API keys
NVIDIA_API_KEY=nvapi-...
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
# Get your API key from opencode.ai/auth (Go subscription required)
OPENCODE_API_KEY=your-opencode-go-api-key

# Proxy ports
PROXY_PORT=443
API_PORT=4040

# Opencode Go endpoint (default) — override to use Zen free tier:
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Retry & failover
PROXY_RETRIES=3
PROXY_BACKOFF_MS=100

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ─── Rate limiting (0 = unlimited) ────────────────────────────────────────────
RATE_LIMIT_GLOBAL=0
RATE_LIMIT_PROVIDER=0
RATE_LIMIT_WINDOW_MS=60000

# ─── Dashboard auth (optional) ────────────────────────────────────────────────
# Can also be set from the Config tab in the dashboard.
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=your_password

# ─── Failover webhook (optional) ──────────────────────────────────────────────
# POST payload sent whenever the router falls back to a backup provider.
# FAILOVER_WEBHOOK_URL=https://hooks.example.com/webhook

# ─── Workspace context hardening (optional) ───────────────────────────────────
# Controls how the proxy wraps agent-context.md to prevent context-confusion.
# off = pass through as-is  |  loose = lightweight note  |  strict = full envelope (default)
# WORKSPACE_CONTEXT_ENVELOPE=strict

# ─── Inline context stripping (optional) ──────────────────────────────────────
# lite       = compressed agent-context-lite.md (~3500 tokens, recommended)
# strip      = full agent-context.md (~10000 tokens)
# passthrough = forward native Antigravity context unchanged (~28000 tokens)
CONTEXT_STRIP_MODE=lite

# ─── Advanced ─────────────────────────────────────────────────────────────────
# Override the absolute path to agent-context.md (defaults to ../../agent-context.md from proxy/)
# AGENT_CONTEXT_PATH=/path/to/agent-context.md

# Override the absolute path to agent-context-lite.md (defaults to ../../agent-context-lite.md from proxy/)
# AGENT_CONTEXT_LITE_PATH=/path/to/agent-context-lite.md

# Server-side request timeout in ms (default: 300000 = 5 minutes)
# REQUEST_TIMEOUT_MS=300000

# Override Google backend IP (skips DNS resolution; useful if DNS is flaky)
# GOOGLE_BACKEND_IP=216.58.214.74
