# Provider priority order (comma-separated, first = primary)
PROVIDER_PRIORITY=nvidia,google,openrouter,groq
PROVIDER=nvidia

# API keys
NVIDIA_API_KEY=nvapi-...
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
# Get your API key from opencode.ai/auth (Go subscription required)
OPENCODE_API_KEY=your-opencode-go-api-key

# Proxy ports
PROXY_PORT=443
API_PORT=4040

# Opencode Go endpoint (default) — override to use Zen free tier:
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Retry & failover
PROXY_RETRIES=3
PROXY_BACKOFF_MS=100

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Rate limiting (0 = unlimited)
RATE_LIMIT_GLOBAL=0
RATE_LIMIT_PROVIDER=0
RATE_LIMIT_WINDOW_MS=60000

# Dashboard auth (can also be set from Config tab)
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=your_password

# Failover webhook (can also be set from Config tab)
# FAILOVER_WEBHOOK_URL=https://hooks.example.com/webhook
